{
  "mcpServers": {
    "workspace": {
      "command": "uvx",
      "args": [
        "workspace-mcp",
        "--tools", "docs", "drive", "calendar", "sheets",
        "--single-user",
        "--transport", "stdio"
      ],
      "env": {
        "GOOGLE_CLIENT_SECRET_PATH": "~/.config/workspace-mcp/client_secret.json"
      }
    },
    "browser": {
      "command": "npx",
      "args": ["-y", "agent-browser-protocol", "--mcp"],
      "env": {
        "ABP_HEADLESS": "${ABP_HEADLESS:-}"
      }
    },
    "shadcn-ui": {
      "command": "npx",
      "args": ["-y", "shadcn-ui-mcp-server"]
    }
  }
}
